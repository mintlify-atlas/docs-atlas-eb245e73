  "keyFeatures": [
    "Multi-agent support (Claude Code, Codex)",
    "Visual UI with diff previews and real-time tool execution",
    "Git worktree isolation for each chat session",
    "Background agents that run in cloud sandboxes",
    "Plan mode with structured planning before execution",
    "MCP integration and plugin marketplace",
    "Automations triggered from GitHub, Linear, or Slack",
    "Built-in git client and terminal",
    "API for programmatic agent execution",
    "Voice input and extended thinking mode"
  ],
  "publicApiSurface": [
    "POST /api/v1/tasks - Create and run agent task",
    "GET /api/v1/tasks/:id - Get task status",
    "POST /api/v1/tasks/:id/messages - Send follow-up message",
    "projects.create - Create new project",
    "projects.list - List all projects",
    "chats.create - Create new chat session",
    "chats.list - List chat sessions",
    "claude.startSession - Start Claude agent session",
    "claude.sendMessage - Send message to agent",
    "codex.startSession - Start Codex agent session",
    "worktreeConfig.get - Get worktree configuration",
    "terminal.create - Create terminal session",
    "files.read - Read file contents",
    "changes.status - Get git status"
  ]
